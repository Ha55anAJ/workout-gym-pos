# Copy to ".env" only if you want to override defaults. All optional.
PORT=4317
# DB_PATH=data/gym.db
# BACKUP_DIR=backups
# auto | device | simulation
FINGERPRINT_MODE=auto
# Name or full path of the ZKFinger SDK library (libzkfp.dll on Windows)
# ZK_LIB_PATH=libzkfp
ENROLL_SAMPLES=3
# Set to 0 to stop auto-opening the browser on start
OPEN_BROWSER=1
