# --- Demo Gym Cloud API configuration ---

# PostgreSQL connection string.
# On Railway, reference the Postgres service and this is injected automatically.
# For local dev, point it at your own Postgres.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/gym

# Secret used to sign owner/staff login tokens. Use a long random string.
JWT_SECRET=change-me-to-a-long-random-string

# Shared secret the gym laptop's sync agent uses to authenticate to the cloud.
SYNC_DEVICE_TOKEN=change-me-too-a-different-long-random-string

# First owner login, created automatically on startup if it doesn't exist.
OWNER_USERNAME=owner
OWNER_PASSWORD=change-me-now
OWNER_NAME=Gym Owner

# PORT is provided by Railway automatically; default 8080 for local dev.
PORT=8080

# Postgres SSL: 'disable' for local dev. Production (Railway) uses SSL automatically.
PGSSL=disable
NODE_ENV=development
